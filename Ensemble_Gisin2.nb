            RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Emark", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Edec", "[", 
            RowBox[{
             RowBox[{"tAL", "[", 
              RowBox[{"[", "j", "]"}], "]"}], ",", 
             RowBox[{"tBL", "[", 
              RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"haveE", "=", 
         RowBox[{"VectorQ", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "Eemp", "]"}], ",", "NumericQ"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"haveT", "=", 
         RowBox[{"VectorQ", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "Eth", "]"}], ",", "NumericQ"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"SempLoc", "=", 
         RowBox[{"If", "[", 
          RowBox[{"haveE", ",", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"SfromMatrix", "[", 
              RowBox[{"Eemp", ",", "n"}], "]"}], ",", "10"}], "]"}], ",", 
           RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SthLoc", "=", 
         RowBox[{"If", "[", 
          RowBox[{"haveT", ",", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"SfromMatrix", "[", 
              RowBox[{"Eth", ",", "n"}], "]"}], ",", "10"}], "]"}], ",", 
           RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SmarkLoc", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"SfromMatrix", "[", 
            RowBox[{"Emark", ",", "n"}], "]"}], ",", "10"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Schoose", "=", 
         RowBox[{"Switch", "[", 
          RowBox[{"mode", ",", "\"\<empirical\>\"", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumericQ", "[", "SempLoc", "]"}], ",", "SempLoc", ",", 
             "SmarkLoc"}], "]"}], ",", "\"\<pairs\>\"", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumericQ", "[", "SthLoc", "]"}], ",", "SthLoc", ",", 
             "SmarkLoc"}], "]"}], ",", "_", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumericQ", "[", "SempLoc", "]"}], ",", "SempLoc", ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"NumericQ", "[", "SthLoc", "]"}], ",", "SthLoc", ",", 
               "SmarkLoc"}], "]"}]}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"counts", "=", 
         RowBox[{"CountsMatrix", "[", "bucketsLocal", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"muForSE", "=", 
         RowBox[{"Switch", "[", 
          RowBox[{"mode", ",", "\"\<empirical\>\"", ",", 
           RowBox[{"If", "[", 
            RowBox[{"haveE", ",", "Eemp", ",", "Emark"}], "]"}], 
           ",", "\"\<pairs\>\"", ",", 
           RowBox[{"If", "[", 
            RowBox[{"haveT", ",", "Eth", ",", "Emark"}], "]"}], ",", "_", ",", 
           RowBox[{"If", "[", 
            RowBox[{"haveE", ",", "Eemp", ",", 
             RowBox[{"If", "[", 
              RowBox[{"haveT", ",", "Eth", ",", "Emark"}], "]"}]}], "]"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sigmaS", "=", 
         RowBox[{"SStdev", "[", 
          RowBox[{"muForSE", ",", "counts", ",", "n"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<n\>\"", "->", "n"}], ",", 
          RowBox[{"\"\<S\>\"", "->", "Schoose"}], ",", 
          RowBox[{"\"\<Slhv\>\"", "->", 
           RowBox[{"LocalBound", "[", "n", "]"}]}], ",", 
          RowBox[{"\"\<selected\>\"", "->", "selectedLocal"}], ",", 
          RowBox[{"\"\<sigmaS\>\"", "->", "sigmaS"}], ",", 
          RowBox[{"\"\<CI95\>\"", "->", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"NumericQ", "[", "sigmaS", "]"}], ",", 
             RowBox[{"Schoose", "+", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "1"}], "}"}], "*", "1.96", "*", 
               "sigmaS"}]}], ",", 
             RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}]}], "]"}]}]}], 
         "|>"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", 
         RowBox[{"--", "Run"}]}]}]}]}], " ", "over", " ", "Ns", " ", "and", " ",
      "make", " ", "the", " ", "plots", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"|", "S_n", "|", 
            RowBox[{"with", " ", "error", " ", "bars"}]}], ")"}], "--"}], 
         "--"}], "--"}], "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"res", "=", 
     RowBox[{"ComputeSForN", "/@", "Ns"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sVals", "=", 
     RowBox[{"res", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<S\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sAbs", "=", 
     RowBox[{"Abs", "@", "sVals"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sLhv", "=", 
     RowBox[{"res", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<Slhv\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"selCounts", "=", 
     RowBox[{"res", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<selected\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sigmas", "=", 
     RowBox[{"res", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<sigmaS\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Plot", "|", "S_n", "|", 
      RowBox[{"with", " ", "1", "\[Sigma]", " ", "error", " ", "bars"}]}], ",", 
     RowBox[{
      RowBox[{
      "and", " ", "the", " ", "local", " ", "realist", " ", "bound", " ", "2",
        "n"}], "-", "2"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sAbsAround", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"NumericQ", "[", "#2", "]"}], ",", 
          RowBox[{"Around", "[", 
           RowBox[{
            RowBox[{"Abs", "[", "#1", "]"}], ",", "#2"}], "]"}], ",", 
          RowBox[{"Around", "[", 
           RowBox[{
            RowBox[{"Abs", "[", "#1", "]"}], ",", "0"}], "]"}]}], "]"}], 
        "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"sVals", ",", "sigmas"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sErrData", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"Ns", ",", "sAbsAround"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sPlotErr", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{"sErrData", ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<n\>\"", ",", "\"\<|S_n|\>\""}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", 
        "->", "\"\<|S_n| vs n (with 1\[Sigma] error bars)\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sLhvLine", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"Ns", ",", "sLhv"}], "}"}], "]"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<S_lhv = 2n-2\>\"", "}"}]}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", "Dashed", "]"}]}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sPlot", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"sPlotErr", ",", "sLhvLine", ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "sPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Selected", " ", "pairs", " ", "vs", " ", "n"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"selPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"Ns", ",", "selCounts"}], "}"}], "]"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<n\>\"", ",", "\"\<selected pairs\>\""}], "}"}]}], ",", 
       RowBox[{"InterpolationOrder", "->", "1"}], ",", 
       RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Selected pairs vs n\>\""}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "selPlot", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Optional", ":", 
     RowBox[{"quick", " ", "table", " ", "of", " ", "results"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"res", "//", "Dataset"}], "\n"}]}]], "Input",
